### Create plan
POST {{baseUrl}}/api/plans
Content-Type: application/json
Accept: application/json

{
  "title": "Premium 12 Months",
  "description": "Twelve months for regular training",
  "durationInMonths": 12,
  "price": 999.00
}

> {%
  client.global.set("planId", response.body.id);
%}

### List plans
GET {{baseUrl}}/api/plans
Accept: application/json

### Get plan by id
GET {{baseUrl}}/api/plans/{{planId}}
Accept: application/json

### Update plan
PUT {{baseUrl}}/api/plans/{{planId}}
Content-Type: application/json
Accept: application/json

{
  "title": "Premium 24 Months",
  "description": "Twenty-four months for long-term training",
  "durationInMonths": 24,
  "price": 1699.00
}

### Delete plan
DELETE {{baseUrl}}/api/plans/{{planId}}
Accept: application/json
